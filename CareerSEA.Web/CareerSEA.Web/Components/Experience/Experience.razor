@page "/experience"
@rendermode InteractiveServer
@using CareerSEA.Contracts
@using CareerSEA.Contracts.Requests
@using CareerSEA.Contracts.Responses
@using MudExtensions
@using MudBlazor
@using System.Text.Json
@using CareerSEA.Web
@using iText.Kernel.Pdf
@using iText.Kernel.Pdf.Canvas.Parser
@using System.IO

@inject ServerApiClient apiClient
@inject ISnackbar Snackbar
@inject PredictionState predictionState
@inject NavigationManager NavManager

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="d-flex justify-center" Style="min-height: 90vh; padding: 0.25rem 0.5rem;">

    <MudCard Elevation="20" Class="w-100" Style="max-width: 56rem;">
        <MudCardHeader Class="border-b-1 border-solid border-lines-default pa-6">
            <CardHeaderContent>
                <MudText Typo="Typo.h4" Align="Align.Center" Class="font-weight-bold">Experience Dashboard</MudText>
                <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mud-text-secondary">
                    Manage, add, and review your saved job experiences.
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent Class="pa-8">

            @* --- UPLOAD CV SECTION --- *@
            <MudText Typo="Typo.h6" GutterBottom="true">Quick Upload</MudText>
            <MudPaper Variant="Variant.Outlined" Class="pa-4 mb-8 d-flex flex-column align-center" Style="border-style: dashed; background-color: var(--mud-palette-background-grey);">
                <MudFileUpload T="IBrowserFile" FilesChanged="UploadAndAnalyzeCv" Accept=".pdf">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   Disabled="@_isSaving">
                            Upload PDF CV
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                <MudText Typo="Typo.caption" Class="mt-2">Llama will automatically extract data from your PDF</MudText>
            </MudPaper>

            <MudText Typo="Typo.h6" GutterBottom="true">Saved Experiences</MudText>

            @if (_isLoading)
            {
                <div class="d-flex justify-center my-4">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (experienceModels == null || !experienceModels.Any())
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="my-4">
                    No experiences found. Add your first job role below!
                </MudAlert>
            }
            else
            {
                <MudStack Spacing="3">
                    @foreach (var exp in experienceModels)
                    {
                        <MudPaper Class="job-entry-paper pa-4" Elevation="2">
                            <MudText Typo="Typo.h6" Color="Color.Primary" GutterBottom="true">@exp.Title</MudText>
                            <MudText Typo="Typo.body2" Class="mb-3" Style="white-space: pre-line;">@exp.Description</MudText>
                            <MudDivider Class="mb-2" />
                            <MudText Typo="Typo.caption">
                                <strong>Skills:</strong> @exp.Skills
                            </MudText>
                        </MudPaper>
                    }
                </MudStack>
            }

            <MudDivider Class="my-8" />

            <MudText Typo="Typo.h6" GutterBottom="true">Add New Experience</MudText>

            <EditForm Model="@model" OnValidSubmit="HandleValidSubmit" FormName="ExperienceForm">
                <DataAnnotationsValidator />

                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudSelectExtended T="string"
                                           @rendermode="InteractiveAuto"
                                           @bind-Value="model.Title"
                                           Label="Job Title"
                                           Variant="Variant.Outlined"
                                           Dense="true"
                                           ItemCollection="_jobTitles"
                                           SearchBox="true"
                                           SearchBoxAutoFocus="true"
                                           SearchBoxClearable="true"
                                           SearchFunc="@(new Func<string, string, bool>(SearchJobTitleFunc))"
                                           HelperText="Select a job title from the list"
                                           Virtualize="true"
                                           For="@(() => model.Title)"
                                           Required="true" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField Label="Job Description"
                                      Placeholder="Enter the full job description here..."
                                      Variant="Variant.Outlined"
                                      Lines="6"
                                      @bind-Value="model.Description"
                                      For="@(() => model.Description)"
                                      Required="true" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField Label="Skills"
                                      Placeholder="Enter you skills here..."
                                      Variant="Variant.Outlined"
                                      @bind-Value="model.Skills"
                                      For="@(() => model.Skills)"
                                      Required="true" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@_isSaving"
                                   Size="Size.Large">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">Saving...</MudText>
                            }
                            else
                            {
                                <MudText>Create Prediction</MudText>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    public List<ExperienceRequest> experienceModels { get; set; } = new();

    [SupplyParameterFromForm(FormName = "ExperienceForm")]
    public ExperienceRequest model { get; set; } = new();

    private bool _isLoading = true;
    private bool _isSaving = false;

    private string[] _jobTitles = JobTitles.Jobs;

    private bool SearchJobTitleFunc(string value, string search)
    {
        if (string.IsNullOrWhiteSpace(search)) return true;
        return value.Contains(search, StringComparison.InvariantCultureIgnoreCase);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadExperiencesAsync();
        }
    }

    // NEW METHOD FOR PDF UPLOAD
    private async Task UploadAndAnalyzeCv(IBrowserFile file)
    {
        if (file == null) return;

        _isSaving = true;
        try
        {
            // 1. Extract text from PDF
            string extractedText = "";
            using (var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
            using (var ms = new MemoryStream())
            {
                await stream.CopyToAsync(ms);
                ms.Position = 0;
                using (var pdfReader = new PdfReader(ms))
                using (var pdfDoc = new PdfDocument(pdfReader))
                {
                    for (int i = 1; i <= pdfDoc.GetNumberOfPages(); i++)
                    {
                        extractedText += PdfTextExtractor.GetTextFromPage(pdfDoc.GetPage(i)) + " ";
                    }
                }
            }

            if (string.IsNullOrWhiteSpace(extractedText)) throw new Exception("PDF is empty or unreadable.");

            var request = new { cvText = extractedText };

            var response = await apiClient.PostAsync<object, BaseResponse>("api/CvToInput/Parse", request);

            // Reusing your exact JSON parsing logic from HandleValidSubmit
            if (response != null && response.Status)
            {
                if (response.Data is System.Text.Json.JsonElement element)
                {
                    var rawJson = element.GetRawText();
                    var options = new JsonSerializerOptions
                    {
                        PropertyNameCaseInsensitive = true,
                        PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower
                    };

                    var prediction = JsonSerializer.Deserialize<AnalysisData>(rawJson, options);

                    if (prediction != null && !string.IsNullOrEmpty(prediction.BestJob))
                    {
                        predictionState.Result = prediction;
                        NavManager.NavigateTo("/result");
                        Snackbar.Add("Analysis Complete!", Severity.Success);
                    }
                    else
                    {
                        Snackbar.Add("Received data but could not read it.", Severity.Error);
                    }
                }
            }
            else
            {
                Snackbar.Add("Server error: " + (response?.Message ?? "Unknown"), Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex}");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    // YOUR EXACT EXISTING METHOD
    private async Task HandleValidSubmit()
    {
        _isSaving = true;
        try
        {
            var response = await apiClient.PostAsync<ExperienceRequest, BaseResponse>("api/ExperiencePrediction/Predict", model);

            if (response != null && response.Status)
            {
                if (response.Data is System.Text.Json.JsonElement element)
                {
                    var rawJson = element.GetRawText();
                    var options = new JsonSerializerOptions
                    {
                        PropertyNameCaseInsensitive = true,
                        PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower
                    };

                    var prediction = JsonSerializer.Deserialize<AnalysisData>(rawJson, options);

                    if (prediction != null && !string.IsNullOrEmpty(prediction.BestJob))
                    {
                        predictionState.Result = prediction;
                        NavManager.NavigateTo("/result");
                        Snackbar.Add("Analysis Complete!", Severity.Success);
                    }
                    else
                    {
                        Snackbar.Add("Received data but could not read it.", Severity.Error);
                    }
                }
                model = new();
            }
            else
            {
                Snackbar.Add("Server error: " + (response?.Message ?? "Unknown"), Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex}");
            Snackbar.Add($"Connection error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    // YOUR EXACT EXISTING METHOD
    private async Task LoadExperiencesAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var result = await apiClient.GetAsync<BaseResponse>("api/ExperiencePrediction/GetForms");

            if (result != null && result.Status && result.Data != null)
            {
                if (result.Data is System.Text.Json.JsonElement element)
                {
                    var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

                    // Handle nested "data" wrapper if it exists
                    if (element.ValueKind == JsonValueKind.Object && element.TryGetProperty("data", out var innerData))
                    {
                        element = innerData;
                    }

                    if (element.ValueKind == JsonValueKind.Array)
                    {
                        experienceModels = JsonSerializer.Deserialize<List<ExperienceRequest>>(element.GetRawText(), options)
                                           ?? new List<ExperienceRequest>();
                    }
                    else if (element.ValueKind == JsonValueKind.Object)
                    {
                        var singleExp = JsonSerializer.Deserialize<ExperienceRequest>(element.GetRawText(), options);
                        if (singleExp != null) experienceModels = new List<ExperienceRequest> { singleExp };
                    }
                }
            }
            else
            {
                experienceModels = new List<ExperienceRequest>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            experienceModels = new List<ExperienceRequest>(); // Added this just to be safe
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}