@page "/experience"
@rendermode InteractiveServer
@using CareerSEA.Contracts
@using CareerSEA.Contracts.Requests
@using CareerSEA.Contracts.Responses
@using MudExtensions
@using MudBlazor
@using System.Text.Json
@using CareerSEA.Web
@using System.IO

@inject ServerApiClient apiClient
@inject ISnackbar Snackbar
@inject PredictionState predictionState
@inject NavigationManager NavManager

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="d-flex justify-center" Style="min-height: 90vh; padding: 0.25rem 0.5rem;">

    <MudCard Elevation="20" Class="w-100" Style="max-width: 56rem;">
        <MudCardHeader Class="border-b-1 border-solid border-lines-default pa-6">
            <CardHeaderContent>
                <MudText Typo="Typo.h4" Align="Align.Center" Class="font-weight-bold">Experience Dashboard</MudText>
                <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mud-text-secondary">
                    Manage, add, and review your saved job experiences.
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent Class="pa-8">

            @* --- UPLOAD CV SECTION --- *@
            <MudText Typo="Typo.h6" GutterBottom="true">Quick Upload</MudText>
            <MudPaper Outlined="true" Class="pa-4 mb-8 d-flex flex-column align-center" Style="border-style: dashed; background-color: var(--mud-palette-background-grey);">
                <MudFileUpload T="IBrowserFile" FilesChanged="UploadAndAnalyzeCv" Accept=".pdf">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   Disabled="@_isSaving">
                            Upload PDF CV
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                <MudText Typo="Typo.caption" Class="mt-2">Qwen will automatically extract data from your PDF</MudText>
            </MudPaper>

            <MudText Typo="Typo.h6" GutterBottom="true">Saved Experiences</MudText>

            @if (_isLoading)
            {
                <div class="d-flex justify-center my-4">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (experienceModels == null || !experienceModels.Any())
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="my-4">
                    No experiences found. Add your first job role below!
                </MudAlert>
            }
            else
            {
                <MudStack Spacing="3">
                    @foreach (var exp in experienceModels)
                    {
                        <MudPaper Class="job-entry-paper pa-4" Elevation="2">
                            <MudText Typo="Typo.h6" Color="Color.Primary" GutterBottom="true">@exp.Title</MudText>
                            <MudText Typo="Typo.body2" Class="mb-3" Style="white-space: pre-line;">@exp.Description</MudText>
                            <MudDivider Class="mb-2" />
                            <MudText Typo="Typo.caption">
                                <strong>Skills:</strong> @exp.Skills
                            </MudText>
                        </MudPaper>
                    }
                </MudStack>
            }

            <MudDivider Class="my-8" />

            <MudText Typo="Typo.h6" GutterBottom="true">Add Experiences</MudText>
            @if (_hasExtractedCvForReview)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                    Review the extracted CV experiences before creating a prediction.
                </MudAlert>
            }

            <EditForm Model="@inlineExperienceModels" OnSubmit="HandlePredictionSubmit" FormName="ExperienceForm">
                <MudStack Spacing="4">
                    @for (var i = 0; i < inlineExperienceModels.Count; i++)
                    {
                        var index = i;

                        <MudPaper @key="inlineExperienceModels[index]" Class="job-entry-paper pa-4" Elevation="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                                <MudText Typo="Typo.h6" Color="Color.Primary">Experience @(index + 1)</MudText>
                                @if (inlineExperienceModels.Count > 1)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Variant="Variant.Text"
                                                   Size="Size.Small"
                                                   Disabled="@_isSaving"
                                                   OnClick="@(() => RemoveExperienceForm(index))"
                                                   aria-label="@($"Remove experience {index + 1}")" />
                                }
                            </MudStack>

                            <MudGrid Spacing="3">
                                <MudItem xs="12">
                                    @* FIXED: Virtualize="false" to prevent parentElement crash *@
                                    <MudSelectExtended T="string"
                                                       @rendermode="InteractiveAuto"
                                                       @bind-Value="inlineExperienceModels[index].Title"
                                                       Label="Job Title"
                                                       Variant="Variant.Outlined"
                                                       Dense="true"
                                                       ItemCollection="_jobTitles"
                                                       SearchBox="true"
                                                       SearchBoxAutoFocus="true"
                                                       SearchBoxClearable="true"
                                                       SearchFunc="@(new Func<string, string, bool>(SearchJobTitleFunc))"
                                                       HelperText="Select a job title from the list"
                                                       Virtualize="false"
                                                       Required="true" />
                                </MudItem>

                                <MudItem xs="12">
                                    <MudTextField Label="Job Description"
                                                  Placeholder="Enter the full job description here..."
                                                  Variant="Variant.Outlined"
                                                  Lines="6"
                                                  @bind-Value="inlineExperienceModels[index].Description"
                                                  Required="true" />
                                </MudItem>

                                <MudItem xs="12">
                                    <MudTextField Label="Skills"
                                                  Placeholder="Enter your skills here (comma separated)..."
                                                  Variant="Variant.Outlined"
                                                  @bind-Value="inlineExperienceModels[index].Skills"
                                                  Required="true" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }

                    <MudButton ButtonType="ButtonType.Button"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true"
                               Disabled="@_isSaving"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddExperienceForm">
                        Add New Experience
                    </MudButton>

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Disabled="@_isSaving"
                               Size="Size.Large">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <MudText Class="ms-2">Saving...</MudText>
                        }
                        else
                        {
                            <MudText>CREATE PREDICTION</MudText>
                        }
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    public List<ExperienceRequest> experienceModels { get; set; } = new();
    public List<ExperienceRequest> inlineExperienceModels { get; set; } = new() { new() };

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _hasExtractedCvForReview = false;

    private string[] _jobTitles = JobTitles.Jobs;

    private bool SearchJobTitleFunc(string value, string search)
    {
        if (string.IsNullOrWhiteSpace(search)) return true;
        return value.Contains(search, StringComparison.InvariantCultureIgnoreCase);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadExperiencesAsync();
        }
    }

    private async Task UploadAndAnalyzeCv(IBrowserFile file)
    {
        if (file == null) return;

        _isSaving = true;
        _hasExtractedCvForReview = false;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            var contentType = string.IsNullOrWhiteSpace(file.ContentType) ? "application/pdf" : file.ContentType;
            var response = await apiClient.PostFileAsync<BaseResponse>("api/CvToInput/Parse", stream, file.Name, contentType);

            if (response == null)
            {
                Snackbar.Add("CV analysis failed. The API returned no response.", Severity.Error);
                return;
            }

            if (!response.Status)
            {
                Snackbar.Add(response.Message ?? "CV analysis failed.", Severity.Error);
                return;
            }

            if (response.Data is System.Text.Json.JsonElement element)
            {
                var options = new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true,
                    PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower
                };

                ExtractedCvResponse? extractedCv = null;

                if (element.ValueKind == JsonValueKind.Object)
                {
                    extractedCv = JsonSerializer.Deserialize<ExtractedCvResponse>(element.GetRawText(), options);
                }
                else if (element.ValueKind == JsonValueKind.Array)
                {
                    extractedCv = new ExtractedCvResponse
                    {
                        Experiences = JsonSerializer.Deserialize<List<ExtractedExperienceDto>>(element.GetRawText(), options) ?? new()
                    };
                }

                var extractedExperiences = extractedCv?.Experiences?
                    .Select(experience => new ExperienceRequest
                    {
                        Title = (experience.Title ?? string.Empty).Trim(),
                        Description = (experience.Description ?? string.Empty).Trim(),
                        Skills = string.Join(", ",
                            (experience.Skills ?? new List<string>())
                                .Select(skill => (skill ?? string.Empty).Trim())
                                .Where(skill => !string.IsNullOrWhiteSpace(skill))
                                .Distinct(StringComparer.OrdinalIgnoreCase))
                    })
                    .Where(experience =>
                        !string.IsNullOrWhiteSpace(experience.Title)
                        || !string.IsNullOrWhiteSpace(experience.Description)
                        || !string.IsNullOrWhiteSpace(experience.Skills))
                    .ToList() ?? new();

                if (extractedExperiences.Any())
                {
                    MergeJobTitles(extractedExperiences.Select(experience => experience.Title));
                    inlineExperienceModels = extractedExperiences;
                    _hasExtractedCvForReview = true;
                    Snackbar.Add($"Extracted {extractedExperiences.Count} experience{(extractedExperiences.Count == 1 ? "" : "s")} from the CV.", Severity.Success);
                    StateHasChanged();
                    return;
                }

                Snackbar.Add("CV extraction completed but no usable experiences were returned.", Severity.Warning);
                return;
            }

            Snackbar.Add("CV extraction finished but no structured experience data was returned.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally { _isSaving = false; }
    }

    private void AddExperienceForm()
    {
        inlineExperienceModels.Add(new ExperienceRequest());
    }

    private void MergeJobTitles(IEnumerable<string> titles)
    {
        _jobTitles = _jobTitles
            .Concat(titles.Where(title => !string.IsNullOrWhiteSpace(title)).Select(title => title.Trim()))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(title => title)
            .ToArray();
    }

    private void RemoveExperienceForm(int index)
    {
        if (inlineExperienceModels.Count <= 1 || index < 0 || index >= inlineExperienceModels.Count)
        {
            return;
        }

        inlineExperienceModels.RemoveAt(index);
    }

    private async Task HandlePredictionSubmit()
    {
        var experiencesToSubmit = inlineExperienceModels
            .Select(experience => new ExperienceRequest
            {
                Title = (experience.Title ?? string.Empty).Trim(),
                Description = (experience.Description ?? string.Empty).Trim(),
                Skills = (experience.Skills ?? string.Empty).Trim()
            })
            .ToList();

        var invalidIndex = experiencesToSubmit.FindIndex(experience =>
            string.IsNullOrWhiteSpace(experience.Title)
            || string.IsNullOrWhiteSpace(experience.Description)
            || string.IsNullOrWhiteSpace(experience.Skills));

        if (invalidIndex >= 0)
        {
            Snackbar.Add($"Complete all fields for experience {invalidIndex + 1}.", Severity.Warning);
            return;
        }

        _isSaving = true;
        try
        {
            var response = await apiClient.PostAsync<List<ExperienceRequest>, BaseResponse>("api/ExperiencePrediction/PredictMany", experiencesToSubmit);

            if (response != null && response.Status && response.Data is System.Text.Json.JsonElement element)
            {
                var rawJson = element.GetRawText();
                var options = new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true,
                    PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower
                };

                var prediction = JsonSerializer.Deserialize<AnalysisData>(rawJson, options);

                if (prediction != null && !string.IsNullOrEmpty(prediction.BestJob))
                {
                    // --- SAVE USER SKILLS FROM FORM TO PREDICTION ---
                    var userSkills = SplitUserSkills(experiencesToSubmit);
                    if (userSkills.Any())
                    {
                        prediction.UserSkills = userSkills;
                    }

                    predictionState.Result = prediction;
                    _hasExtractedCvForReview = false;
                    NavManager.NavigateTo("/result");
                    Snackbar.Add("Analysis Complete!", Severity.Success);
                    return;
                }
            }

            Snackbar.Add(response?.Message ?? "Prediction response was incomplete.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Connection error: {ex.Message}", Severity.Error);
        }
        finally { _isSaving = false; }
    }

    private static List<string> SplitUserSkills(IEnumerable<ExperienceRequest> experiences)
    {
        return experiences
            .SelectMany(experience => experience.Skills.Split(new[] { ',', '.', ';' }, StringSplitOptions.RemoveEmptyEntries))
            .Select(skill => skill.Trim())
            .Where(skill => !string.IsNullOrWhiteSpace(skill))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task LoadExperiencesAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var result = await apiClient.GetAsync<BaseResponse>("api/ExperiencePrediction/GetForms");
            if (result != null && result.Status && result.Data is System.Text.Json.JsonElement element)
            {
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                if (element.ValueKind == JsonValueKind.Object && element.TryGetProperty("data", out var innerData))
                    element = innerData;

                if (element.ValueKind == JsonValueKind.Array)
                    experienceModels = JsonSerializer.Deserialize<List<ExperienceRequest>>(element.GetRawText(), options) ?? new();
            }
        }
        catch { experienceModels = new(); }
        finally { _isLoading = false; StateHasChanged(); }
    }
}
