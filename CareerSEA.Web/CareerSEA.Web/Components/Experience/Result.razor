@page "/result"
@rendermode InteractiveServer

@using CareerSEA.Contracts.DTOs
@using CareerSEA.Contracts.Requests
@using MudBlazor
@using CareerSEA.Web

@inject PredictionState predictionState
@inject NavigationManager NavigationManager
@inject TokenStore tokenStore
@inject ServerApiClient ApiClient

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-8">

    <MudCard Elevation="4" Class="rounded-xl position-relative">

        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="absolute left-0 top-0 ma-4 z-10"
                       OnClick="@(() => NavigationManager.NavigateTo("/experience"))" />

        <MudCardHeader Class="d-flex flex-column align-center py-8">
            <MudText Typo="Typo.h5" Align="Align.Center" Class="font-weight-bold">
                AI Analysis Results
            </MudText>
        </MudCardHeader>

        <MudCardContent Class="pa-8">

            @if (_data == null)
            {
                <MudAlert Severity="Severity.Warning">
                    Analysis data not found. Please run the experience analysis again.
                </MudAlert>
            }
            else
            {
                <MudGrid Spacing="4" Justify="Justify.Center" Class="mb-8 border-b pb-8 mud-border-lines-default">
                    <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary font-weight-bold">CURRENT PROFILE</MudText>
                        <MudText Typo="Typo.h6">@tokenStore.Username</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary font-weight-bold">BEST MATCH</MudText>
                        <MudText Typo="Typo.h6" Class="font-weight-bold text-capitalize" Color="@GetColorByScore(_data.MatchScore)">
                            @(_data.BestJob ?? "Unknown")
                        </MudText>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Class="mt-2"
                                   Disabled="@_isLoading"
                                   OnClick="@(() => SearchJobsAsync(_data.BestJob))">
                            @(_isLoading && _currentSearchTerm == _data.BestJob ? "Loading..." : "View Openings")
                        </MudButton>
                    </MudItem>

                    <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary font-weight-bold">SCORE</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold" Color="@GetColorByScore(_data.MatchScore)">
                            @((_data.MatchScore * 100).ToString("0"))%
                        </MudText>
                    </MudItem>
                </MudGrid>

                <div class="mb-8">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Top 3 Alternatives</MudText>

                    @if (_data.Recommendations != null && _data.Recommendations.Any())
                    {
                        <MudStack Spacing="3">
                            @foreach (var job in _data.Recommendations.OrderByDescending(r => r.Score).Take(3))
                            {
                                var percent = (int)(job.Score * 100);

                                <MudPaper Outlined="true" Class="pa-4 rounded-lg">
                                    <div class="d-flex justify-space-between align-center mb-2">
                                        <div class="d-flex align-center gap-2">
                                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@job.Label</MudText>

                                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                                           Size="Size.Small"
                                                           OnClick="@(() => SearchJobsAsync(job.Label))"
                                                           Color="@(_currentSearchTerm == job.Label ? Color.Primary : Color.Default)" />
                                        </div>
                                        <MudChip T="string" Size="Size.Small" Color="@GetColorByScore(job.Score)" Variant="Variant.Text">
                                            @percent% Match
                                        </MudChip>
                                    </div>
                                    <MudProgressLinear Value="@percent" Color="@GetColorByScore(job.Score)" Rounded="true" Size="Size.Medium" />
                                </MudPaper>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No alternative recommendations available.</MudAlert>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_currentSearchTerm))
                {
                    <MudDivider Class="my-8" />

                    <div class="mb-8 animate-fade-in">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">
                            Active Listings: <span class="mud-text-primary">@_currentSearchTerm</span>
                        </MudText>

                        @if (_isLoading)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4 rounded" />
                        }
                        else if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_errorMessage</MudAlert>
                        }
                        else if (_jobListings != null && _jobListings.Any())
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="rounded-lg overflow-hidden">
                                <div style="max-height: 400px; overflow-y: auto;">
                                    @* FIXED: Virtualize="false" to prevent JS crashes *@
                                    <MudList T="string" Dense="true">
                                        @foreach (var job in _jobListings)
                                        {
                                            <MudListItem Href="@job.Link" Target="_blank">
                                                <div class="d-flex justify-space-between align-center">
                                                    <div>
                                                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@job.Title</MudText>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@job.Company • @job.Location</MudText>
                                                    </div>
                                                    <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Default" />
                                                </div>
                                            </MudListItem>
                                            <MudDivider Light="true" />
                                        }
                                    </MudList>
                                </div>
                                <div class="pa-2 bg-gray-100 border-t">
                                    <MudText Typo="Typo.caption" Align="Align.Center" Class="d-block mud-text-secondary">
                                        Jobs provided by Adzuna
                                    </MudText>
                                </div>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No active listings found for this specific title.</MudAlert>
                        }
                    </div>
                }

                <MudDivider Class="my-8" />

                @* --- SKILL GAP SECTION --- *@
                <div class="mb-8">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Skill Gap Analysis</MudText>
                    <MudPaper Outlined="true" Class="pa-6 rounded-lg">
                        @if (_skillGap == null && !_isLoadingGap && string.IsNullOrEmpty(_gapError))
                        {
                            <MudText Typo="Typo.body1" Class="mb-4">
                                Discover which technologies you need to learn to become a <strong>@(_data.BestJob)</strong>.
                            </MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadSkillGapAsync">Analyze My Skills</MudButton>
                        }
                        else if (_isLoadingGap)
                        {
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="d-block mx-auto my-4" />
                            <MudText Align="Align.Center" Class="mud-text-secondary">Analyzing O*NET database...</MudText>
                        }
                        else if (!string.IsNullOrEmpty(_gapError))
                        {
                            <MudAlert Severity="Severity.Error">@_gapError</MudAlert>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="LoadSkillGapAsync" Class="mt-2">Try Again</MudButton>
                        }
                        else if (_skillGap != null)
                        {
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Target Role: @_skillGap.OnetOccupationTitle</MudText>

                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold text-success mb-2">Matched Skills</MudText>
                                    @if (_skillGap.TechnologyGap?.MatchedSkills != null && _skillGap.TechnologyGap.MatchedSkills.Any())
                                    {
                                        <MudStack Spacing="1">
                                            @foreach (var skill in _skillGap.TechnologyGap.MatchedSkills)
                                            {
                                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" Class="mr-2" />@skill</MudText>
                                            }
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No direct matches found.</MudText>
                                    }
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold text-error mb-2">Missing Skills</MudText>
                                    @if (_skillGap.TechnologyGap?.MissingSkills != null && _skillGap.TechnologyGap.MissingSkills.Any())
                                    {
                                        <MudStack Spacing="1">
                                            @foreach (var skill in _skillGap.TechnologyGap.MissingSkills.Take(10))
                                            {
                                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" Class="mr-2" />@skill</MudText>
                                            }
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">You have all the required skills!</MudText>
                                    }
                                </MudItem>
                            </MudGrid>
                        }
                    </MudPaper>
                </div>

                <MudDivider Class="my-8" />

                @* --- COURSES SECTION --- *@
                <div class="mb-8">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Recommended Courses</MudText>
                    <MudPaper Outlined="true" Class="pa-6 rounded-lg">
                        @if (_resources == null && !_isLoadingResources && string.IsNullOrEmpty(_resourceError))
                        {
                            <MudText Typo="Typo.body1" Class="mb-4">
                                Find top-rated courses on YouTube, Udemy, and Coursera to fill your skill gaps.
                            </MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="LoadResourcesAsync">Find Courses</MudButton>
                        }
                        else if (_isLoadingResources)
                        {
                            <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Class="d-block mx-auto my-4" />
                            <MudText Align="Align.Center" Class="mud-text-secondary">Searching the web for the best courses...</MudText>
                        }
                        else if (!string.IsNullOrEmpty(_resourceError))
                        {
                            <MudAlert Severity="Severity.Error">@_resourceError</MudAlert>
                            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="LoadResourcesAsync" Class="mt-2">Try Again</MudButton>
                        }
                        else if (_resources != null && _resources.Any())
                        {
                            <MudExpansionPanels MultiExpansion="true">
                                @foreach (var group in _resources)
                                {
                                    <MudExpansionPanel Text="@($"Learn: {group.Skill}")">
                                        @* FIXED: Virtualize="false" here as well *@
                                        <MudList T="string" Dense="true">
                                            @foreach (var res in group.Resources)
                                            {
                                                <MudListItem Href="@res.Url" Target="_blank">
                                                    <div class="d-flex align-center">
                                                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Class="mr-3 mud-text-secondary" />
                                                        <div>
                                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@res.Title</MudText>
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@res.Provider</MudText>
                                                        </div>
                                                    </div>
                                                </MudListItem>
                                            }
                                        </MudList>
                                    </MudExpansionPanel>
                                }
                            </MudExpansionPanels>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info">No specific courses found for these skills.</MudAlert>
                        }
                    </MudPaper>
                </div>
            }

        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private AnalysisData? _data;

    private List<JobListingDto> _jobListings = new();
    private bool _isLoading;
    private string _currentSearchTerm = string.Empty;
    private string _errorMessage = string.Empty;

    private SkillGapEnvelopeDTO? _skillGap;
    private bool _isLoadingGap;
    private string _gapError = string.Empty;

    private List<ResourceGroupDTO>? _resources;
    private bool _isLoadingResources;
    private string _resourceError = string.Empty;

    protected override void OnInitialized()
    {
        _data = predictionState.Result;
    }

    private async Task SearchJobsAsync(string? jobTitle)
    {
        if (string.IsNullOrWhiteSpace(jobTitle)) return;

        _currentSearchTerm = jobTitle;
        _isLoading = true;
        _errorMessage = "";
        _jobListings = new(); // Reset the list
        StateHasChanged();

        try
        {
            _jobListings = await ApiClient.SearchJobsAsync(jobTitle, "gb");
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to load jobs. " + ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadSkillGapAsync()
    {
        if (_data == null || string.IsNullOrWhiteSpace(_data.BestJob)) return;

        _isLoadingGap = true;
        _gapError = "";
        StateHasChanged();

        try
        {
            // Use the real UserSkills we saved on the previous page
            var userSkills = _data.UserSkills ?? new List<string>();

            _skillGap = await ApiClient.GetSkillGapAsync(new SkillGapRequest
            {
                BestJob = _data.BestJob,
                UserSkills = userSkills
            });
        }
        catch (Exception ex)
        {
            _gapError = "Failed to load skill gap. " + ex.Message;
        }
        finally
        {
            _isLoadingGap = false;
            StateHasChanged();
        }
    }

    private async Task LoadResourcesAsync()
    {
        if (_data == null || string.IsNullOrWhiteSpace(_data.BestJob)) return;

        _isLoadingResources = true;
        _resourceError = "";
        StateHasChanged();

        try
        {
            var missingSkills = _skillGap?.TechnologyGap?.MissingSkills ?? new List<string>();

            _resources = await ApiClient.GetResourcesAsync(new ResourceRecommendationRequest
            {
                BestJob = _data.BestJob,
                MissingSkills = missingSkills,
                UserSkills = _data.UserSkills ?? new List<string>()
            });
        }
        catch (Exception ex)
        {
            _resourceError = "Failed to load courses. " + ex.Message;
        }
        finally
        {
            _isLoadingResources = false;
            StateHasChanged();
        }
    }

    private Color GetColorByScore(float score) => score switch
    {
        >= 0.6f => Color.Success,
        >= 0.5f => Color.Primary,
        >= 0.4f => Color.Warning,
        _ => Color.Error
    };
}
